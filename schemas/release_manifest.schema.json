{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FCB release manifest",
  "type": "object",
  "required": [
    "schema_version",
    "app_id",
    "release_version",
    "channel",
    "platform",
    "arch",
    "backend",
    "artifact_hash",
    "artifact_size"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "app_id": {
      "type": "string",
      "format": "uuid"
    },
    "release_version": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "arch": {
      "type": "string",
      "minLength": 1
    },
    "backend": {
      "type": "string",
      "minLength": 1
    },
    "artifact_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "artifact_size": {
      "type": "integer",
      "minimum": 0
    }
  }
}
