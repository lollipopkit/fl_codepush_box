{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FCB config",
  "type": "object",
  "required": ["active_app_id", "apps"],
  "additionalProperties": false,
  "properties": {
    "active_app_id": {
      "type": "string"
    },
    "apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "channel", "update", "security", "platforms"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "channel": {
            "type": "string"
          },
          "update": {
            "type": "object",
            "required": ["check_on_startup", "activation"],
            "properties": {
              "check_on_startup": {
                "type": "boolean"
              },
              "activation": {
                "type": "string"
              }
            }
          },
          "security": {
            "type": "object",
            "required": ["public_key_id"],
            "properties": {
              "public_key_id": {
                "type": "string"
              }
            }
          },
          "platforms": {
            "type": "object",
            "required": ["android", "ios"],
            "properties": {
              "android": {
                "$ref": "#/$defs/platform"
              },
              "ios": {
                "$ref": "#/$defs/platform"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "platform": {
      "type": "object",
      "required": ["enabled", "backend", "abi"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "backend": {
          "type": "string"
        },
        "abi": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
