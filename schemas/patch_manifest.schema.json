{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FCB patch manifest",
  "type": "object",
  "required": [
    "schema_version",
    "app_id",
    "release_version",
    "patch_number",
    "channel",
    "created_at",
    "backend",
    "platform",
    "arch",
    "payload",
    "policy",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "app_id": {
      "type": "string",
      "format": "uuid"
    },
    "release_version": {
      "type": "string",
      "minLength": 1
    },
    "patch_number": {
      "type": "integer",
      "minimum": 1
    },
    "channel": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "backend": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "arch": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "required": ["kind", "compression", "hash", "size", "download_url"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "compression": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "download_url": {
          "type": "string",
          "minLength": 1
        },
        "diff_algorithm": {
          "type": "string",
          "minLength": 1
        },
        "base_hash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "output_hash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": ["rollout_percentage", "allow_downgrade"],
      "additionalProperties": false,
      "properties": {
        "rollout_percentage": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "allow_downgrade": {
          "type": "boolean"
        }
      }
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "key_id", "value"],
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "ed25519"
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
