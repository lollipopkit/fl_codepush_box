+int SetFcbAotArtifactPath(void* user_data, const char* artifact_path) {
+  if (user_data == nullptr || artifact_path == nullptr ||
+      artifact_path[0] == '\0') {
+    return -1;
+  }
+  auto* settings = reinterpret_cast<flutter::Settings*>(user_data);
+  settings->application_library_paths.clear();
+  settings->application_library_paths.emplace_back(artifact_path);
+  return 0;
+}
+
+void MaybeApplyFcbSnapshotReplace(flutter::Settings& settings,
+                                  const std::string& engine_caches_path) {
+  const std::string cache_dir = engine_caches_path + "/fcb";
+  __android_log_print(ANDROID_LOG_INFO, "Flutter",
+                      "FCB snapshot_replace cache: %s", cache_dir.c_str());
+  FcbInitParams params = {};
+  params.platform = "android";
+#if defined(__aarch64__)
+  params.arch = "arm64-v8a";
+#elif defined(__arm__)
+  params.arch = "armeabi-v7a";
+#elif defined(__x86_64__)
+  params.arch = "x86_64";
+#elif defined(__i386__)
+  params.arch = "x86";
+#endif
+  params.cache_dir = cache_dir.c_str();
+  params.check_on_startup = 0;
+  if (fcb_init(&params) != 0) {
+    __android_log_print(ANDROID_LOG_WARN, "Flutter", "FCB init failed: %s",
+                        fcb_last_error());
+    return;
+  }
+  FcbEnginePatchDecision decision = {};
+  const int rc = fcb_apply_android_snapshot_replace(
+      fcb_get_launch_patch, SetFcbAotArtifactPath, &settings, &decision);
+  if (rc == 1) {
+    __android_log_print(ANDROID_LOG_INFO, "Flutter",
+                        "FCB snapshot_replace patch %d: %s",
+                        decision.patch_number, decision.artifact_path);
+  } else {
+    __android_log_print(ANDROID_LOG_INFO, "Flutter",
+                        "FCB snapshot_replace not applied rc=%d error=%s", rc,
+                        fcb_last_error());
+  }
+}
+
 fml::jni::ScopedJavaGlobalRef<jclass>* g_flutter_jni_class = nullptr;

