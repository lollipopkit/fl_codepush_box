+
+  // FCB: Try to initialize the FCB updater. Best-effort; if the native
+  // library is not present (stock Engine) or init fails, the Engine falls
+  // back to loading the bundled libapp.so with no patch applied.
+  private void tryInitFcb(Context context) {
+    try {
+      java.io.File fcbCacheDir = new java.io.File(context.getCacheDir(), ".fcb/cache");
+      fcbCacheDir.mkdirs();
+      // The public key and server URL are typically configured from the Dart
+      // package, but for Engine-level init we pass empty strings so the updater
+      // can at least read state.json from a previous download.
+      // The Dart package will call fcb_init() again with full config.
+      nativeFcbInit(fcbCacheDir.getAbsolutePath(), "", "");
+    } catch (Throwable t) {
+      Log.w(TAG, "FCB init failed, falling back to bundled artifact", t);
+    }
+  }
 
